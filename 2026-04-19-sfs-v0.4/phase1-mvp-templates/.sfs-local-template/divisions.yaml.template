# .sfs-local/divisions.yaml
# MVP minimal divisions config (PHASE1-KICKOFF-CHECKLIST §2.3 기준)
# Solon docset 쪽 divisions.schema.yaml v1.1 와 호환되는 subset.

version: 1.0-mvp-minimal
project: "<PROJECT-NAME>"
runtime: claude-code   # Codex / Gemini 미사용 (Phase 1 scope)
created: "<DATE>"

divisions:
  dev:
    activation_state: active
    lead: "사용자 직접 (self-lead, no Opus lead agent yet)"
    notes: "구현 주도. D (do) step 의 main owner."

  strategy-pm:
    activation_state: active
    lead: "사용자 직접"
    notes: "brainstorm / plan / review 산출물 owner. P-1 + P + C step."

  qa:
    activation_state: abstract
    reason: "MVP 1 cycle 에서는 manual smoke test 로 대체. cycle 3 누적 후 activate 검토."

  design:
    activation_state: abstract
    reason: "shadcn/ui 등 기존 디자인 시스템 차용. 자체 design 본부 불필요."

  infra:
    activation_state: abstract
    reason: "<DEPLOY> 재사용 가정. 필요 시 cycle 2~3 에서 activate 검토."

  taxonomy:
    activation_state: abstract
    reason: "관리자 페이지 도메인 taxonomy 는 cycle 2~3 누적 후 도입."

# Phase 1 MVP 기본 활성 본부 = dev + strategy-pm 2 개.
# 나머지 4 개는 abstract — 필요 시 대화에서 선언적으로 activate 승격.
# 승격 기록은 .sfs-local/decisions/<N>-activate-<division>.md 에 남김.
