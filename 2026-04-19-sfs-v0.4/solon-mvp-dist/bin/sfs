#!/usr/bin/env bash
# sfs — Solon Product global CLI entrypoint.
#
# Packaged runtimes (Homebrew, source clone, local tarball) should expose this
# file on PATH. Consumer repos keep `.sfs-local/` as state/config only.

set -euo pipefail

find_dist_dir() {
  local source="${BASH_SOURCE[0]:-$0}"
  while [[ -L "${source}" ]]; do
    local link_dir link_target
    link_dir="$(cd "$(dirname "${source}")" && pwd)"
    link_target="$(readlink "${source}")"
    case "${link_target}" in
      /*) source="${link_target}" ;;
      *)  source="${link_dir}/${link_target}" ;;
    esac
  done

  local bin_dir
  bin_dir="$(cd -P "$(dirname "${source}")" && pwd)"

  local candidate
  for candidate in \
    "${SFS_DIST_DIR:-}" \
    "${bin_dir}/.." \
    "${bin_dir}" \
    "${bin_dir}/../share/solon-product" \
    "${bin_dir}/../share/solon"; do
    [[ -n "${candidate}" ]] || continue
    if [[ -d "${candidate}/templates/.sfs-local-template/scripts" ]]; then
      cd "${candidate}" && pwd
      return 0
    fi
  done

  echo "cannot locate Solon runtime templates; set SFS_DIST_DIR" >&2
  return 1
}

DIST_DIR="$(find_dist_dir)"
RUNTIME_DIR="${DIST_DIR}/templates/.sfs-local-template"

usage() {
  cat <<'EOF'
Usage:
  sfs init [--yes] [--layout thin|vendored]
  sfs upgrade [--skip-existing] [--no-self-upgrade] [--interactive]
  sfs update [--skip-existing]          # compatibility alias for upgrade
  sfs uninstall [--keep-artifacts|--remove-all] [--remove-docs|--keep-docs]
  sfs agent install <claude|gemini|codex|all> [--skip-existing]
  sfs <command> [args]

Commands:
  agent install, upgrade, update, uninstall
  version [--check]
  status, start, guide, auth, adopt, brainstorm, plan, implement, review, decision, report, tidy, retro, commit, loop

Project state defaults to .sfs-local/. Override with SFS_LOCAL_DIR when needed.

First-time project setup after Homebrew install:
  cd /path/to/your-project
  sfs init --yes
  sfs status
  sfs guide
EOF
}

agent_usage() {
  cat <<'EOF'
Usage:
  sfs agent install <claude|gemini|codex|all> [--skip-existing]

Installs thin LLM-agent adapter files into the current project:
  claude  -> .claude/skills/sfs/SKILL.md + .claude/commands/sfs.md
  gemini  -> .gemini/commands/sfs.toml
  codex   -> .agents/skills/sfs/SKILL.md

Existing changed files are archived under .sfs-local/archives/agent-install-backups/.
EOF
}

upgrade_usage() {
  cat <<'EOF'
Usage:
  sfs upgrade [--skip-existing] [--no-self-upgrade] [--interactive]
  sfs update [--skip-existing] [--no-self-upgrade]   # compatibility alias

Updates the current project from the latest Solon runtime:
  - if this CLI is installed by Homebrew, runs `brew update` + `brew upgrade sfs` first
  - if this CLI is installed by Scoop, runs `scoop update` + `scoop update sfs` first
  - updates managed SFS runtime docs/adapters with backup safety
  - preserves sprint/decision/event history and project-specific docs
  - syncs Claude/Gemini/Codex agent entry points

Use `--interactive` to run the project-file preview instead of the safe
non-interactive default. Use `--no-self-upgrade` or `SFS_UPDATE_SELF=0` to skip
the package-manager step.
EOF
}

version_command() {
  local check_latest=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --check|check)
        check_latest=1
        shift
        ;;
      -h|--help)
        cat <<'EOF'
Usage:
  sfs version
  sfs version --check

Prints the installed SFS runtime version. With --check, also checks the latest
published Solon Product tag on GitHub and tells you whether `sfs upgrade` is
needed.
EOF
        return 0
        ;;
      *)
        echo "unexpected arg for version: $1" >&2
        return 1
        ;;
    esac
  done

  local version_file="${DIST_DIR}/VERSION"
  local version="unknown"
  if [[ -f "${version_file}" ]]; then
    version="$(head -1 "${version_file}" 2>/dev/null || true)"
    version="${version:-unknown}"
  fi
  printf 'sfs %s\n' "${version}"
  if [[ "${check_latest}" == "1" ]]; then
    local latest
    if latest="$(latest_release_version 2>/dev/null)" && [[ -n "${latest}" ]]; then
      printf 'latest %s\n' "${latest}"
      if [[ "${version}" == "${latest}" ]]; then
        printf 'status up-to-date\n'
      else
        printf 'status upgrade-available\n'
        printf 'next sfs upgrade\n'
      fi
    else
      printf 'latest unknown\n'
      printf 'status check-failed\n'
      printf 'hint check your network or package manager metadata\n'
      return 2
    fi
  fi
}

latest_release_version() {
  command -v git >/dev/null 2>&1 || return 1
  local repo="${SFS_RELEASE_REPO_URL:-https://github.com/MJ-0701/solon-product.git}"
  local refs line sha ref tag ver major minor patch
  local best="" best_major=-1 best_minor=-1 best_patch=-1
  refs="$(git ls-remote --tags --refs "${repo}" 'refs/tags/v*-product' 2>/dev/null)" || return 1
  while IFS= read -r line; do
    [[ -n "${line}" ]] || continue
    sha="${line%%$'\t'*}"
    ref="${line#*$'\t'}"
    [[ -n "${sha}" && -n "${ref}" ]] || continue
    tag="${ref##*/v}"
    case "${tag}" in
      *-product) ver="${tag%-product}" ;;
      *) continue ;;
    esac
    IFS=. read -r major minor patch <<< "${ver}"
    [[ "${major}" =~ ^[0-9]+$ && "${minor}" =~ ^[0-9]+$ && "${patch}" =~ ^[0-9]+$ ]] || continue
    if (( major > best_major )) \
      || (( major == best_major && minor > best_minor )) \
      || (( major == best_major && minor == best_minor && patch > best_patch )); then
      best="${tag}"
      best_major="${major}"
      best_minor="${minor}"
      best_patch="${patch}"
    fi
  done <<< "${refs}"
  [[ -n "${best}" ]] || return 1
  printf '%s\n' "${best}"
}

project_local_dir() {
  printf '%s\n' "${SFS_LOCAL_DIR:-.sfs-local}"
}

project_onboarding_hint() {
  local cmd="${1:-command}"
  cat <<EOF
Solon CLI is installed, but this project is not initialized yet.

Current directory:
  ${PWD}

First-time project setup:
  sfs init --yes
  sfs status
  sfs guide

What this means:
  brew install MJ-0701/solon-product/sfs  installs the global sfs CLI on this Mac.
  sfs init --yes                          injects SFS.md, .sfs-local/, and agent adapters into this project.
  sfs upgrade                             upgrades the global CLI first, then refreshes this project.

Tip:
  If this folder is not a git repo yet, sfs init --yes will run git init for you.

You tried:
  sfs ${cmd}
EOF
}

ensure_project_initialized() {
  local cmd="${1:-command}"
  local local_dir
  local_dir="$(project_local_dir)"
  if [[ -d "${local_dir}" && -f "${local_dir}/VERSION" ]]; then
    return 0
  fi
  project_onboarding_hint "${cmd}" >&2
  case "${cmd}" in
    guide|help|-h|--help)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

backup_and_copy() {
  local src="$1"
  local dst_rel="$2"
  local skip_existing="${3:-0}"
  local dst="${PWD}/${dst_rel}"

  if [[ ! -f "${src}" ]]; then
    echo "missing packaged adapter: ${src}" >&2
    return 4
  fi

  mkdir -p "$(dirname "${dst}")"

  if [[ -f "${dst}" ]]; then
    if cmp -s "${src}" "${dst}"; then
      echo "unchanged: ${dst_rel}"
      return 0
    fi
    if [[ "${skip_existing}" == "1" ]]; then
      echo "skip existing: ${dst_rel}"
      return 0
    fi

    local ts backup_dir safe_rel
    ts="$(date +%Y%m%d-%H%M%S)"
    backup_dir="${PWD}/.sfs-local/archives/agent-install-backups/${ts}"
    safe_rel="${dst_rel//\//__}"
    mkdir -p "${backup_dir}"
    cp "${dst}" "${backup_dir}/${safe_rel}"
    cp "${src}" "${dst}"
    echo "updated: ${dst_rel} (archive: .sfs-local/archives/agent-install-backups/${ts}/${safe_rel})"
    return 0
  fi

  cp "${src}" "${dst}"
  echo "installed: ${dst_rel}"
}

install_agent_adapter() {
  local target="${1:-}" skip_existing="${2:-0}"
  case "${target}" in
    claude|claude-code)
      backup_and_copy "${DIST_DIR}/templates/.claude/commands/sfs.md" ".claude/commands/sfs.md" "${skip_existing}"
      backup_and_copy "${DIST_DIR}/templates/.claude/commands/sfs.md" ".claude/skills/sfs/SKILL.md" "${skip_existing}"
      ;;
    gemini)
      backup_and_copy "${DIST_DIR}/templates/.gemini/commands/sfs.toml" ".gemini/commands/sfs.toml" "${skip_existing}"
      ;;
    codex)
      backup_and_copy "${DIST_DIR}/templates/.agents/skills/sfs/SKILL.md" ".agents/skills/sfs/SKILL.md" "${skip_existing}"
      ;;
    all)
      install_agent_adapter claude "${skip_existing}"
      install_agent_adapter gemini "${skip_existing}"
      install_agent_adapter codex "${skip_existing}"
      ;;
    *)
      echo "unknown agent: ${target}" >&2
      agent_usage >&2
      return 1
      ;;
  esac
}

agent_command() {
  local sub="${1:-}"
  shift || true

  case "${sub}" in
    install)
      local target="" skip_existing=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --skip-existing)
            skip_existing=1
            shift
            ;;
          -h|--help)
            agent_usage
            return 0
            ;;
          -*)
            echo "unknown arg: $1" >&2
            agent_usage >&2
            return 1
            ;;
          *)
            if [[ -n "${target}" ]]; then
              echo "unexpected extra arg: $1" >&2
              agent_usage >&2
              return 1
            fi
            target="$1"
            shift
            ;;
        esac
      done
      if [[ -z "${target}" ]]; then
        echo "missing agent target" >&2
        agent_usage >&2
        return 1
      fi
      install_agent_adapter "${target}" "${skip_existing}"
      ;;
    -h|--help|help|"")
      agent_usage
      ;;
    *)
      echo "unknown agent subcommand: ${sub}" >&2
      agent_usage >&2
      return 1
      ;;
  esac
}

upgrade_command() {
  local skip_existing=0
  local no_self_upgrade="${SFS_SKIP_SELF_UPGRADE:-0}"
  local interactive=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skip-existing)
        skip_existing=1
        shift
        ;;
      --no-self-upgrade)
        no_self_upgrade=1
        shift
        ;;
      --interactive)
        interactive=1
        shift
        ;;
      -h|--help)
        upgrade_usage
        return 0
        ;;
      *)
        echo "unknown arg: $1" >&2
        upgrade_usage >&2
        return 1
        ;;
    esac
  done

  ensure_project_initialized upgrade || return $?
  if [[ "${no_self_upgrade}" != "1" && "${SFS_UPDATE_SELF:-1}" != "0" ]]; then
    self_upgrade_if_homebrew "${skip_existing}"
    self_upgrade_if_scoop "${skip_existing}"
  fi
  if [[ "${interactive}" == "1" ]]; then
    bash "${DIST_DIR}/upgrade.sh"
  else
    bash "${DIST_DIR}/upgrade.sh" --yes
  fi
  echo "agent adapters sync:"
  install_agent_adapter all "${skip_existing}"
}

is_homebrew_runtime() {
  command -v brew >/dev/null 2>&1 || return 1
  local prefix info
  prefix="$(brew --prefix sfs 2>/dev/null || true)"
  [[ -n "${prefix}" ]] || return 1
  case "${DIST_DIR}" in
    "${prefix}"|"${prefix}/"*) ;;
    *) return 1 ;;
  esac
  info="$(brew info sfs 2>/dev/null || true)"
  printf '%s\n' "${info}" | grep -q 'mj-0701/solon-product/sfs'
}

self_upgrade_if_homebrew() {
  local skip_existing="${1:-0}" sfs_bin
  is_homebrew_runtime || return 0

  echo "global runtime self-upgrade:"
  echo "  brew update"
  if ! brew update; then
    echo "brew update failed; rerun with SFS_UPDATE_SELF=0 to use the current runtime only" >&2
    return 1
  fi

  echo "  brew upgrade sfs"
  if ! brew upgrade sfs; then
    echo "brew upgrade sfs failed; rerun with SFS_UPDATE_SELF=0 to use the current runtime only" >&2
    return 1
  fi

  sfs_bin="$(command -v sfs 2>/dev/null || true)"
  [[ -n "${sfs_bin}" ]] || return 0

  echo "reloading installed sfs runtime..."
  if [[ "${skip_existing}" == "1" ]]; then
    exec env SFS_SKIP_SELF_UPGRADE=1 "${sfs_bin}" upgrade --skip-existing --no-self-upgrade
  fi
  exec env SFS_SKIP_SELF_UPGRADE=1 "${sfs_bin}" upgrade --no-self-upgrade
}

is_scoop_runtime() {
  case "${DIST_DIR}" in
    */scoop/apps/sfs/*|*/Scoop/apps/sfs/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

run_scoop_command() {
  if command -v scoop >/dev/null 2>&1; then
    scoop "$@"
    return $?
  fi

  local ps=""
  for candidate in powershell.exe pwsh.exe powershell pwsh; do
    if command -v "${candidate}" >/dev/null 2>&1; then
      ps="${candidate}"
      break
    fi
  done
  [[ -n "${ps}" ]] || return 127

  local joined="scoop"
  local arg
  for arg in "$@"; do
    joined="${joined} ${arg}"
  done
  "${ps}" -NoProfile -ExecutionPolicy Bypass -Command "${joined}"
}

self_upgrade_if_scoop() {
  local skip_existing="${1:-0}" sfs_bin
  is_scoop_runtime || return 0

  echo "global runtime self-upgrade:"
  echo "  scoop update"
  if ! run_scoop_command update; then
    echo "scoop update failed; rerun with SFS_UPDATE_SELF=0 to use the current runtime only" >&2
    return 1
  fi

  echo "  scoop update sfs"
  if ! run_scoop_command update sfs; then
    echo "scoop update sfs failed; rerun with SFS_UPDATE_SELF=0 to use the current runtime only" >&2
    return 1
  fi

  sfs_bin="$(command -v sfs 2>/dev/null || true)"
  [[ -n "${sfs_bin}" ]] || return 0

  echo "reloading installed sfs runtime..."
  if [[ "${skip_existing}" == "1" ]]; then
    exec env SFS_SKIP_SELF_UPGRADE=1 "${sfs_bin}" upgrade --skip-existing --no-self-upgrade
  fi
  exec env SFS_SKIP_SELF_UPGRADE=1 "${sfs_bin}" upgrade --no-self-upgrade
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

case "${1:-}" in
  /sfs|sfs|\$sfs)
    shift
    if [[ $# -eq 0 ]]; then
      usage
      exit 0
    fi
    ;;
esac

case "${1:-}" in
  init|install)
    shift
    exec bash "${DIST_DIR}/install.sh" --layout thin "$@"
    ;;
  agent)
    shift
    agent_command "$@"
    exit $?
    ;;
  upgrade)
    shift
    upgrade_command "$@"
    exit $?
    ;;
  update)
    shift
    echo "sfs update is a compatibility alias; prefer: sfs upgrade" >&2
    upgrade_command "$@"
    exit $?
    ;;
  version|-v|--version)
    shift || true
    version_command "$@"
    exit $?
    ;;
  uninstall)
    shift
    exec bash "${DIST_DIR}/uninstall.sh" "$@"
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
esac

case "${1:-}" in
  status|start|guide|auth|adopt|brainstorm|plan|implement|review|decision|report|tidy|retro|commit|loop)
    if ! ensure_project_initialized "${1:-command}"; then
      exit 1
    fi
    if [[ "${1:-}" == "guide" && ! -f "$(project_local_dir)/VERSION" ]]; then
      exit 0
    fi
    ;;
esac

export SFS_RUNTIME_DIR="${RUNTIME_DIR}"
export SFS_DIST_DIR="${DIST_DIR}"
export SFS_LOCAL_DIR="${SFS_LOCAL_DIR:-.sfs-local}"

exec bash "${RUNTIME_DIR}/scripts/sfs-dispatch.sh" "$@"
