#!/usr/bin/env bash
# sfs — Solon Product global CLI entrypoint.
#
# Packaged runtimes (Homebrew, source clone, local tarball) should expose this
# file on PATH. Consumer repos keep `.sfs-local/` as state/config only.

set -euo pipefail

sfs_requested_command() {
  local first="${1:-}"
  case "${first}" in
    /sfs|sfs|\$sfs)
      shift || true
      ;;
  esac
  printf '%s\n' "${1:-help}"
}

sfs_default_timeout_sec() {
  local cmd="$1"
  case "${cmd}" in
    review)
      printf '%s\n' "${SFS_REVIEW_COMMAND_TIMEOUT_SEC:-1800}"
      ;;
    loop)
      printf '%s\n' "${SFS_LOOP_COMMAND_TIMEOUT_SEC:-7200}"
      ;;
    init|install|upgrade|update|uninstall|agent)
      printf '%s\n' "${SFS_MUTATION_COMMAND_TIMEOUT_SEC:-1800}"
      ;;
    auth)
      printf '%s\n' "${SFS_AUTH_COMMAND_TIMEOUT_SEC:-300}"
      ;;
    version)
      printf '%s\n' "${SFS_VERSION_COMMAND_TIMEOUT_SEC:-300}"
      ;;
    *)
      printf '%s\n' "${SFS_COMMAND_DEFAULT_TIMEOUT_SEC:-300}"
      ;;
  esac
}

sfs_resolved_timeout_sec() {
  local cmd="$1" timeout
  timeout="${SFS_COMMAND_TIMEOUT_SEC:-$(sfs_default_timeout_sec "${cmd}")}"
  case "${timeout}" in
    ''|*[!0-9]*)
      echo "invalid SFS_COMMAND_TIMEOUT_SEC: ${timeout} (expected integer seconds, 0 disables)" >&2
      return 7
      ;;
  esac
  printf '%s\n' "${timeout}"
}

sfs_enter_call_depth() {
  local depth max_depth
  depth="${SFS_CALL_DEPTH:-0}"
  max_depth="${SFS_MAX_CALL_DEPTH:-6}"
  case "${depth}" in ''|*[!0-9]*) depth=0 ;; esac
  case "${max_depth}" in ''|*[!0-9]*) max_depth=6 ;; esac
  depth=$((depth + 1))
  if (( depth > max_depth )); then
    echo "sfs safety stop: recursive command depth ${depth} exceeded max ${max_depth}" >&2
    echo "hint: check for a command/adapter that re-invokes sfs without making progress" >&2
    exit 124
  fi
  export SFS_CALL_DEPTH="${depth}"
}

sfs_run_self_with_watchdog() {
  local timeout="$1"
  shift
  local self="$1"
  shift
  local cmd="$1"
  shift || true
  local child="" watchdog="" marker="" rc=0 grace
  grace="${SFS_WATCHDOG_KILL_GRACE_SEC:-3}"
  case "${grace}" in ''|*[!0-9]*) grace=3 ;; esac

  marker="$(mktemp "${TMPDIR:-/tmp}/sfs-watchdog.XXXXXX")" || return 1
  rm -f "${marker}"

  (
    export SFS_WATCHDOG_CHILD=1
    bash "${self}" "$@"
  ) &
  child=$!

  (
    sleep "${timeout}"
    if kill -0 "${child}" 2>/dev/null; then
      {
        printf 'sfs safety timeout: command `%s` exceeded %ss and was stopped\n' "${cmd}" "${timeout}"
        printf 'hint: set SFS_COMMAND_TIMEOUT_SEC=<seconds> to raise the cap, or 0 to disable for a trusted one-off run\n'
      } >&2
      printf 'timeout\n' > "${marker}" 2>/dev/null || true
      kill -TERM "${child}" 2>/dev/null || true
      sleep "${grace}"
      kill -KILL "${child}" 2>/dev/null || true
    fi
  ) &
  watchdog=$!

  trap 'kill "${child:-}" "${watchdog:-}" 2>/dev/null || true; rm -f "${marker:-}"; exit 130' INT TERM
  wait "${child}" || rc=$?
  kill "${watchdog}" 2>/dev/null || true
  wait "${watchdog}" 2>/dev/null || true
  trap - INT TERM

  if [[ -f "${marker}" ]]; then
    rc=124
  fi
  rm -f "${marker}"
  return "${rc}"
}

sfs_enter_call_depth
if [[ "${SFS_WATCHDOG_CHILD:-0}" != "1" ]]; then
  _sfs_cmd="$(sfs_requested_command "$@")"
  _sfs_timeout="$(sfs_resolved_timeout_sec "${_sfs_cmd}")" || exit $?
  if (( _sfs_timeout > 0 )); then
    sfs_run_self_with_watchdog "${_sfs_timeout}" "${BASH_SOURCE[0]:-$0}" "${_sfs_cmd}" "$@"
    exit $?
  fi
fi

find_dist_dir() {
  local source="${BASH_SOURCE[0]:-$0}"
  local hops=0
  while [[ -L "${source}" ]]; do
    hops=$((hops + 1))
    if (( hops > 40 )); then
      echo "sfs safety stop: too many symlink hops while locating runtime" >&2
      return 1
    fi
    local link_dir link_target
    link_dir="$(cd "$(dirname "${source}")" && pwd)"
    link_target="$(readlink "${source}")"
    case "${link_target}" in
      /*) source="${link_target}" ;;
      *)  source="${link_dir}/${link_target}" ;;
    esac
  done

  local bin_dir
  bin_dir="$(cd -P "$(dirname "${source}")" && pwd)"

  local candidate
  for candidate in \
    "${SFS_DIST_DIR:-}" \
    "${bin_dir}/.." \
    "${bin_dir}" \
    "${bin_dir}/../share/solon-product" \
    "${bin_dir}/../share/solon"; do
    [[ -n "${candidate}" ]] || continue
    if [[ -d "${candidate}/templates/.sfs-local-template/scripts" ]]; then
      cd "${candidate}" && pwd
      return 0
    fi
  done

  echo "cannot locate Solon runtime templates; set SFS_DIST_DIR" >&2
  return 1
}

DIST_DIR="$(find_dist_dir)"
RUNTIME_DIR="${DIST_DIR}/templates/.sfs-local-template"

usage() {
  cat <<'EOF'
Usage:
  sfs init [--yes] [--layout thin|vendored]
  sfs upgrade [--skip-existing] [--no-self-upgrade] [--interactive]
  sfs update [--skip-existing]          # compatibility alias for upgrade
  sfs uninstall [--keep-artifacts|--remove-all] [--remove-docs|--keep-docs]
  sfs agent install <claude|gemini|codex|all> [--skip-existing]
  sfs context path <kernel|index|commands/name.md|policies/name.md>
  sfs <command> [args]

Commands:
  agent install, upgrade, update, uninstall
  version [--check]
  status, start, guide, auth, profile, division, adopt, brainstorm, plan, implement, review, decision, report, tidy, retro, commit, loop

Project state defaults to .sfs-local/. Override with SFS_LOCAL_DIR when needed.

First-time project setup after Homebrew install:
  cd /path/to/your-project
  sfs init --yes
  sfs status
  sfs guide
EOF
}

context_usage() {
  cat <<'EOF'
Usage:
  sfs context path <kernel|index|commands/name.md|policies/name.md>
  sfs context cat  <kernel|index|commands/name.md|policies/name.md>

Read-only helper for agent adapters. In thin layout the managed context lives in
the packaged global runtime; project-local .sfs-local/context files are optional
overrides only.
EOF
}

context_resolve_rel() {
  local key="${1:-}"
  case "${key}" in
    kernel) printf '%s\n' "kernel.md" ;;
    index|_INDEX.md) printf '%s\n' "_INDEX.md" ;;
    commands/*.md|policies/*.md) printf '%s\n' "${key}" ;;
    *)
      echo "unknown context key: ${key}" >&2
      return 1
      ;;
  esac
}

context_command() {
  local mode="${1:-}" rel path
  shift || true
  case "${mode}" in
    path|cat) ;;
    -h|--help|help|"")
      context_usage
      return 0
      ;;
    *)
      echo "unknown context subcommand: ${mode}" >&2
      context_usage >&2
      return 1
      ;;
  esac
  rel="$(context_resolve_rel "${1:-}")" || return 1
  if [[ -f "$(project_local_dir)/context/${rel}" ]]; then
    path="$(project_local_dir)/context/${rel}"
  else
    path="${RUNTIME_DIR}/context/${rel}"
  fi
  [[ -f "${path}" ]] || {
    echo "context file not found: ${rel}" >&2
    return 1
  }
  if [[ "${mode}" == "path" ]]; then
    printf '%s\n' "${path}"
  else
    cat "${path}"
  fi
}

agent_usage() {
  cat <<'EOF'
Usage:
  sfs agent install <claude|gemini|codex|all> [--skip-existing]

Installs thin LLM-agent adapter files into the current project:
  claude  -> .claude/skills/sfs/SKILL.md + .claude/commands/sfs.md
  gemini  -> .gemini/commands/sfs.toml
  codex   -> .agents/skills/sfs/SKILL.md

Existing changed files are archived under .sfs-local/archives/agent-install-backups/.
EOF
}

upgrade_usage() {
  cat <<'EOF'
Usage:
  sfs upgrade [--skip-existing] [--no-self-upgrade] [--interactive]
  sfs update [--skip-existing] [--no-self-upgrade]   # compatibility alias

Updates the current project from the latest Solon runtime:
  - if this CLI is installed by Homebrew, refreshes the Solon tap and runs
    `brew update` + `brew upgrade MJ-0701/solon-product/sfs` first
  - if this CLI is installed by Scoop, runs `scoop update` + `scoop update sfs` first
  - updates managed SFS runtime docs/adapters with backup safety
  - preserves sprint/decision/event history and project-specific docs
  - syncs Claude/Gemini/Codex agent entry points

Use `--interactive` to run the project-file preview instead of the safe
non-interactive default. Use `--no-self-upgrade` or `SFS_UPDATE_SELF=0` to skip
the package-manager step.
EOF
}

version_command() {
  local check_latest=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --check|check)
        check_latest=1
        shift
        ;;
      -h|--help)
        cat <<'EOF'
Usage:
  sfs version
  sfs version --check

Prints the installed SFS runtime version. With --check, also checks the latest
published Solon Product tag on GitHub and tells you whether `sfs upgrade` is
needed.
EOF
        return 0
        ;;
      *)
        echo "unexpected arg for version: $1" >&2
        return 1
        ;;
    esac
  done

  local version_file="${DIST_DIR}/VERSION"
  local version="unknown"
  if [[ -f "${version_file}" ]]; then
    version="$(head -1 "${version_file}" 2>/dev/null || true)"
    version="${version:-unknown}"
  fi
  printf 'sfs %s\n' "${version}"
  if [[ "${check_latest}" == "1" ]]; then
    local latest
    if latest="$(latest_release_version 2>/dev/null)" && [[ -n "${latest}" ]]; then
      printf 'latest %s\n' "${latest}"
      if [[ "${version}" == "${latest}" ]]; then
        printf 'status up-to-date\n'
      else
        printf 'status upgrade-available\n'
        printf 'next sfs upgrade\n'
      fi
    else
      printf 'latest unknown\n'
      printf 'status check-failed\n'
      printf 'hint check your network or package manager metadata\n'
      return 2
    fi
  fi
}

latest_release_version() {
  command -v git >/dev/null 2>&1 || return 1
  local repo="${SFS_RELEASE_REPO_URL:-https://github.com/MJ-0701/solon-product.git}"
  local refs line sha ref tag ver major minor patch
  local best="" best_major=-1 best_minor=-1 best_patch=-1
  refs="$(git ls-remote --tags --refs "${repo}" 'refs/tags/v*-product' 2>/dev/null)" || return 1
  while IFS= read -r line; do
    [[ -n "${line}" ]] || continue
    sha="${line%%$'\t'*}"
    ref="${line#*$'\t'}"
    [[ -n "${sha}" && -n "${ref}" ]] || continue
    tag="${ref##*/v}"
    case "${tag}" in
      *-product) ver="${tag%-product}" ;;
      *) continue ;;
    esac
    IFS=. read -r major minor patch <<< "${ver}"
    [[ "${major}" =~ ^[0-9]+$ && "${minor}" =~ ^[0-9]+$ && "${patch}" =~ ^[0-9]+$ ]] || continue
    if (( major > best_major )) \
      || (( major == best_major && minor > best_minor )) \
      || (( major == best_major && minor == best_minor && patch > best_patch )); then
      best="${tag}"
      best_major="${major}"
      best_minor="${minor}"
      best_patch="${patch}"
    fi
  done <<< "${refs}"
  [[ -n "${best}" ]] || return 1
  printf '%s\n' "${best}"
}

sfs_runtime_version() {
  local version_file="${DIST_DIR}/VERSION"
  local version="unknown"
  if [[ -f "${version_file}" ]]; then
    version="$(head -1 "${version_file}" 2>/dev/null || true)"
  fi
  printf '%s\n' "${version:-unknown}"
}

sfs_project_version() {
  local local_dir="$1"
  local version_file="${local_dir}/VERSION"
  local version=""
  [[ -f "${version_file}" ]] || return 1
  version="$(awk '/^solon_mvp_version:/ {print $2; exit}' "${version_file}" 2>/dev/null || true)"
  [[ -n "${version}" ]] || return 1
  printf '%s\n' "${version}"
}

sfs_parse_product_version() {
  local version="$1" base major minor patch
  case "${version}" in
    *-product) base="${version%-product}" ;;
    *-mvp) base="${version%-mvp}" ;;
    *) return 1 ;;
  esac
  IFS=. read -r major minor patch <<< "${base}"
  [[ "${major}" =~ ^[0-9]+$ && "${minor}" =~ ^[0-9]+$ && "${patch}" =~ ^[0-9]+$ ]] || return 1
  printf '%s %s %s\n' "${major}" "${minor}" "${patch}"
}

sfs_version_lag_steps() {
  local current="$1" latest="$2"
  local c_major c_minor c_patch l_major l_minor l_patch
  read -r c_major c_minor c_patch < <(sfs_parse_product_version "${current}") || return 1
  read -r l_major l_minor l_patch < <(sfs_parse_product_version "${latest}") || return 1

  if (( l_major < c_major )) \
    || (( l_major == c_major && l_minor < c_minor )) \
    || (( l_major == c_major && l_minor == c_minor && l_patch <= c_patch )); then
    printf '0\n'
    return 0
  fi

  if (( l_major == c_major && l_minor == c_minor )); then
    printf '%s\n' "$((l_patch - c_patch))"
  else
    # A minor/major jump is definitely beyond the stale-notice threshold, even
    # though exact release count requires scanning all tags.
    printf '%s\n' "${SFS_VERSION_NOTICE_THRESHOLD:-5}"
  fi
}

read_notice_state_value() {
  local state_file="$1" key="$2"
  [[ -f "${state_file}" ]] || return 1
  awk -F= -v key="${key}" '$1 == key {print $2; exit}' "${state_file}" 2>/dev/null
}

write_notice_state() {
  local state_file="$1" checked_at="$2" latest="$3"
  mkdir -p "$(dirname "${state_file}")" 2>/dev/null || return 0
  {
    printf 'last_checked_epoch=%s\n' "${checked_at}"
    printf 'latest=%s\n' "${latest}"
  } > "${state_file}" 2>/dev/null || true
}

maybe_show_stale_version_notice() {
  local cmd="${1:-command}"
  case "${SFS_VERSION_NOTICE:-1}" in 0|false|off|no) return 0 ;; esac
  case "${cmd}" in init|install|upgrade|update|uninstall|version|-v|--version|help|-h|--help|agent) return 0 ;; esac

  local local_dir state_file now ttl last_checked threshold latest runtime_version project_version
  local runtime_lag=0 project_lag=0 notice_source="runtime" notice_version lag
  local_dir="$(project_local_dir)"
  [[ -d "${local_dir}" && -f "${local_dir}/VERSION" ]] || return 0
  if [[ "${SFS_VERSION_NOTICE_FORCE:-0}" != "1" && ! -t 2 ]]; then
    return 0
  fi

  threshold="${SFS_VERSION_NOTICE_THRESHOLD:-5}"
  ttl="${SFS_VERSION_NOTICE_TTL_SEC:-86400}"
  case "${threshold}" in ''|*[!0-9]*) threshold=5 ;; esac
  case "${ttl}" in ''|*[!0-9]*) ttl=86400 ;; esac

  state_file="${local_dir}/cache/version-notice.env"
  now="$(date +%s 2>/dev/null || printf '0')"
  last_checked="$(read_notice_state_value "${state_file}" last_checked_epoch || true)"
  if [[ "${SFS_VERSION_NOTICE_FORCE:-0}" != "1" && "${now}" != "0" && "${last_checked}" =~ ^[0-9]+$ ]]; then
    if (( now - last_checked < ttl )); then
      return 0
    fi
  fi

  if ! latest="$(latest_release_version 2>/dev/null)" || [[ -z "${latest}" ]]; then
    write_notice_state "${state_file}" "${now}" "unknown"
    return 0
  fi
  write_notice_state "${state_file}" "${now}" "${latest}"

  runtime_version="$(sfs_runtime_version)"
  runtime_lag="$(sfs_version_lag_steps "${runtime_version}" "${latest}" 2>/dev/null || printf '0')"
  project_version="$(sfs_project_version "${local_dir}" 2>/dev/null || true)"
  if [[ -n "${project_version}" ]]; then
    project_lag="$(sfs_version_lag_steps "${project_version}" "${latest}" 2>/dev/null || printf '0')"
  fi

  if (( project_lag >= runtime_lag )); then
    notice_source="project"
    notice_version="${project_version:-${runtime_version}}"
    lag="${project_lag}"
  else
    notice_source="runtime"
    notice_version="${runtime_version}"
    lag="${runtime_lag}"
  fi

  if (( lag < threshold )); then
    return 0
  fi

  {
    printf 'sfs notice: your Solon %s version is %s; latest is %s (%s releases behind).\n' "${notice_source}" "${notice_version}" "${latest}" "${lag}"
    printf 'newer product-flow features may be missing. Changelog: https://github.com/MJ-0701/solon-product/blob/main/CHANGELOG.md\n'
    printf 'update when ready: sfs upgrade\n'
    printf 'snooze: SFS_VERSION_NOTICE=0 or SFS_VERSION_NOTICE_TTL_SEC=<seconds>\n'
  } >&2

  if [[ "${cmd}" == "status" && "${SFS_VERSION_NOTICE_PROMPT:-1}" != "0" && -t 0 ]]; then
    local answer
    printf 'update now after reviewing the changelog? [y/N]: ' >&2
    read -r answer || answer=""
    case "${answer}" in
      y|Y|yes|YES)
        upgrade_command --skip-existing
        exit $?
        ;;
    esac
  fi
}

project_local_dir() {
  printf '%s\n' "${SFS_LOCAL_DIR:-.sfs-local}"
}

project_onboarding_hint() {
  local cmd="${1:-command}"
  cat <<EOF
Solon CLI is installed, but this project is not initialized yet.

Current directory:
  ${PWD}

First-time project setup:
  sfs init --yes
  sfs status
  sfs guide

What this means:
  brew install MJ-0701/solon-product/sfs  installs the global sfs CLI on this Mac.
  sfs init --yes                          injects SFS.md, .sfs-local/, and agent adapters into this project.
  sfs upgrade                             upgrades the global CLI first, then refreshes this project.

Tip:
  If this folder is not a git repo yet, sfs init --yes will run git init for you.

You tried:
  sfs ${cmd}
EOF
}

ensure_project_initialized() {
  local cmd="${1:-command}"
  local local_dir
  local_dir="$(project_local_dir)"
  if [[ -d "${local_dir}" && -f "${local_dir}/VERSION" ]]; then
    return 0
  fi
  project_onboarding_hint "${cmd}" >&2
  case "${cmd}" in
    guide|help|-h|--help)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

AGENT_BACKUP_DIR=""
AGENT_BACKUP_STAGE=""
AGENT_BACKUP_LIST=""
AGENT_BACKUP_REL=""

agent_backup_file() {
  local dst="$1" dst_rel="$2"
  local ts rel_dir archive_rel

  if [[ -z "${AGENT_BACKUP_DIR}" ]]; then
    ts="$(date +%Y%m%d-%H%M%S)"
    AGENT_BACKUP_DIR="${PWD}/.sfs-local/archives/agent-install-backups/${ts}"
    AGENT_BACKUP_STAGE="${AGENT_BACKUP_DIR}/.stage"
    AGENT_BACKUP_LIST="${AGENT_BACKUP_DIR}/.items"
    mkdir -p "${AGENT_BACKUP_STAGE}" || return 5
  fi

  rel_dir="$(dirname "${dst_rel}")"
  mkdir -p "${AGENT_BACKUP_STAGE}/${rel_dir}" || return 5
  cp "${dst}" "${AGENT_BACKUP_STAGE}/${dst_rel}" || return 5
  printf '%s\n' "${dst_rel}" >> "${AGENT_BACKUP_LIST}" || return 5
  AGENT_BACKUP_REL="${AGENT_BACKUP_DIR#${PWD}/}/agent-adapter-backup.tar.gz"
}

finalize_agent_backup() {
  local archive_file manifest count
  [[ -n "${AGENT_BACKUP_DIR}" && -d "${AGENT_BACKUP_STAGE}" ]] || return 0
  archive_file="${AGENT_BACKUP_DIR}/agent-adapter-backup.tar.gz"
  manifest="${AGENT_BACKUP_DIR}/manifest.txt"
  count="$(find "${AGENT_BACKUP_STAGE}" -type f 2>/dev/null | wc -l | tr -d '[:space:]')"
  if [[ "${count:-0}" == "0" ]]; then
    rm -rf "${AGENT_BACKUP_STAGE}" "${AGENT_BACKUP_LIST}" 2>/dev/null || true
    rmdir "${AGENT_BACKUP_DIR}" 2>/dev/null || true
    AGENT_BACKUP_DIR=""
    AGENT_BACKUP_STAGE=""
    AGENT_BACKUP_LIST=""
    AGENT_BACKUP_REL=""
    return 0
  fi

  {
    echo "SFS agent adapter backup"
    echo "generated_at: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "reason: pre-install rollback copies for Claude/Gemini/Codex adapter files"
    echo "archive: ${archive_file}"
    echo "count: ${count}"
    echo
    echo "items:"
    if [[ -f "${AGENT_BACKUP_LIST}" ]]; then
      sort -u "${AGENT_BACKUP_LIST}" | sed 's/^/- /'
    else
      find "${AGENT_BACKUP_STAGE}" -type f 2>/dev/null | sort | while IFS= read -r staged; do
        printf -- "- %s\n" "${staged#${AGENT_BACKUP_STAGE}/}"
      done
    fi
  } > "${manifest}" || return 5

  tar -czf "${archive_file}" -C "${AGENT_BACKUP_STAGE}" . || return 5
  rm -rf "${AGENT_BACKUP_STAGE}" "${AGENT_BACKUP_LIST}" || return 5
  echo "agent backup bundle: ${archive_file#${PWD}/} (${count} files)"
  AGENT_BACKUP_DIR=""
  AGENT_BACKUP_STAGE=""
  AGENT_BACKUP_LIST=""
  AGENT_BACKUP_REL=""
}

backup_and_copy() {
  local src="$1"
  local dst_rel="$2"
  local skip_existing="${3:-0}"
  local dst="${PWD}/${dst_rel}"

  if [[ ! -f "${src}" ]]; then
    echo "missing packaged adapter: ${src}" >&2
    return 4
  fi

  mkdir -p "$(dirname "${dst}")"

  if [[ -f "${dst}" ]]; then
    if cmp -s "${src}" "${dst}"; then
      echo "unchanged: ${dst_rel}"
      return 0
    fi
    if [[ "${skip_existing}" == "1" ]]; then
      echo "skip existing: ${dst_rel}"
      return 0
    fi

    local archive_rel
    agent_backup_file "${dst}" "${dst_rel}" || return 5
    archive_rel="${AGENT_BACKUP_REL}"
    cp "${src}" "${dst}"
    echo "updated: ${dst_rel} (archive: ${archive_rel})"
    return 0
  fi

  cp "${src}" "${dst}"
  echo "installed: ${dst_rel}"
}

install_agent_adapter() {
  local target="${1:-}" skip_existing="${2:-0}"
  case "${target}" in
    claude|claude-code)
      backup_and_copy "${DIST_DIR}/templates/.claude/commands/sfs.md" ".claude/commands/sfs.md" "${skip_existing}"
      backup_and_copy "${DIST_DIR}/templates/.claude/commands/sfs.md" ".claude/skills/sfs/SKILL.md" "${skip_existing}"
      finalize_agent_backup
      ;;
    gemini)
      backup_and_copy "${DIST_DIR}/templates/.gemini/commands/sfs.toml" ".gemini/commands/sfs.toml" "${skip_existing}"
      finalize_agent_backup
      ;;
    codex)
      backup_and_copy "${DIST_DIR}/templates/.agents/skills/sfs/SKILL.md" ".agents/skills/sfs/SKILL.md" "${skip_existing}"
      finalize_agent_backup
      ;;
    all)
      backup_and_copy "${DIST_DIR}/templates/.claude/commands/sfs.md" ".claude/commands/sfs.md" "${skip_existing}"
      backup_and_copy "${DIST_DIR}/templates/.claude/commands/sfs.md" ".claude/skills/sfs/SKILL.md" "${skip_existing}"
      backup_and_copy "${DIST_DIR}/templates/.gemini/commands/sfs.toml" ".gemini/commands/sfs.toml" "${skip_existing}"
      backup_and_copy "${DIST_DIR}/templates/.agents/skills/sfs/SKILL.md" ".agents/skills/sfs/SKILL.md" "${skip_existing}"
      finalize_agent_backup
      ;;
    *)
      echo "unknown agent: ${target}" >&2
      agent_usage >&2
      return 1
      ;;
  esac
}

agent_command() {
  local sub="${1:-}"
  shift || true

  case "${sub}" in
    install)
      local target="" skip_existing=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --skip-existing)
            skip_existing=1
            shift
            ;;
          -h|--help)
            agent_usage
            return 0
            ;;
          -*)
            echo "unknown arg: $1" >&2
            agent_usage >&2
            return 1
            ;;
          *)
            if [[ -n "${target}" ]]; then
              echo "unexpected extra arg: $1" >&2
              agent_usage >&2
              return 1
            fi
            target="$1"
            shift
            ;;
        esac
      done
      if [[ -z "${target}" ]]; then
        echo "missing agent target" >&2
        agent_usage >&2
        return 1
      fi
      install_agent_adapter "${target}" "${skip_existing}"
      ;;
    -h|--help|help|"")
      agent_usage
      ;;
    *)
      echo "unknown agent subcommand: ${sub}" >&2
      agent_usage >&2
      return 1
      ;;
  esac
}

upgrade_command() {
  local skip_existing=0
  local no_self_upgrade="${SFS_SKIP_SELF_UPGRADE:-0}"
  local interactive=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skip-existing)
        skip_existing=1
        shift
        ;;
      --no-self-upgrade)
        no_self_upgrade=1
        shift
        ;;
      --interactive)
        interactive=1
        shift
        ;;
      -h|--help)
        upgrade_usage
        return 0
        ;;
      *)
        echo "unknown arg: $1" >&2
        upgrade_usage >&2
        return 1
        ;;
    esac
  done

  ensure_project_initialized upgrade || return $?
  if [[ "${no_self_upgrade}" != "1" && "${SFS_UPDATE_SELF:-1}" != "0" ]]; then
    self_upgrade_if_homebrew "${skip_existing}"
    self_upgrade_if_scoop "${skip_existing}"
  fi
  if [[ "${interactive}" == "1" ]]; then
    bash "${DIST_DIR}/upgrade.sh"
  else
    bash "${DIST_DIR}/upgrade.sh" --yes
  fi
  echo "agent adapters sync:"
  install_agent_adapter all "${skip_existing}"
}

is_homebrew_runtime() {
  command -v brew >/dev/null 2>&1 || return 1
  local prefix info
  prefix="$(brew --prefix MJ-0701/solon-product/sfs 2>/dev/null || brew --prefix sfs 2>/dev/null || true)"
  [[ -n "${prefix}" ]] || return 1
  case "${DIST_DIR}" in
    "${prefix}"|"${prefix}/"*) ;;
    *) return 1 ;;
  esac
  info="$(brew info MJ-0701/solon-product/sfs 2>/dev/null || brew info sfs 2>/dev/null || true)"
  printf '%s\n' "${info}" | grep -q 'mj-0701/solon-product/sfs'
}

refresh_homebrew_tap() {
  local tap_repo
  tap_repo="$(brew --repo MJ-0701/solon-product 2>/dev/null || true)"
  [[ -n "${tap_repo}" && -d "${tap_repo}/.git" ]] || return 0

  echo "  git -C ${tap_repo} pull --ff-only"
  if ! git -C "${tap_repo}" pull --ff-only; then
    echo "Homebrew Solon tap refresh failed; rerun after network/tap state is fixed" >&2
    return 1
  fi
}

self_upgrade_if_homebrew() {
  local skip_existing="${1:-0}" sfs_bin
  is_homebrew_runtime || return 0

  echo "global runtime self-upgrade:"
  refresh_homebrew_tap || return 1

  echo "  brew update"
  if ! brew update; then
    echo "brew update failed; continuing after explicit Solon tap refresh" >&2
  fi

  echo "  brew upgrade MJ-0701/solon-product/sfs"
  if ! brew upgrade MJ-0701/solon-product/sfs; then
    echo "brew upgrade MJ-0701/solon-product/sfs failed; rerun with SFS_UPDATE_SELF=0 to use the current runtime only" >&2
    return 1
  fi

  sfs_bin="$(command -v sfs 2>/dev/null || true)"
  [[ -n "${sfs_bin}" ]] || return 0

  echo "reloading installed sfs runtime..."
  if [[ "${skip_existing}" == "1" ]]; then
    exec env SFS_SKIP_SELF_UPGRADE=1 "${sfs_bin}" upgrade --skip-existing --no-self-upgrade
  fi
  exec env SFS_SKIP_SELF_UPGRADE=1 "${sfs_bin}" upgrade --no-self-upgrade
}

is_scoop_runtime() {
  case "${DIST_DIR}" in
    */scoop/apps/sfs/*|*/Scoop/apps/sfs/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

run_scoop_command() {
  if command -v scoop >/dev/null 2>&1; then
    scoop "$@"
    return $?
  fi

  local ps=""
  for candidate in powershell.exe pwsh.exe powershell pwsh; do
    if command -v "${candidate}" >/dev/null 2>&1; then
      ps="${candidate}"
      break
    fi
  done
  [[ -n "${ps}" ]] || return 127

  local joined="scoop"
  local arg
  for arg in "$@"; do
    joined="${joined} ${arg}"
  done
  "${ps}" -NoProfile -ExecutionPolicy Bypass -Command "${joined}"
}

self_upgrade_if_scoop() {
  local skip_existing="${1:-0}" sfs_bin
  is_scoop_runtime || return 0

  echo "global runtime self-upgrade:"
  echo "  scoop update"
  if ! run_scoop_command update; then
    echo "scoop update failed; rerun with SFS_UPDATE_SELF=0 to use the current runtime only" >&2
    return 1
  fi

  echo "  scoop update sfs"
  if ! run_scoop_command update sfs; then
    echo "scoop update sfs failed; rerun with SFS_UPDATE_SELF=0 to use the current runtime only" >&2
    return 1
  fi

  sfs_bin="$(command -v sfs 2>/dev/null || true)"
  [[ -n "${sfs_bin}" ]] || return 0

  echo "reloading installed sfs runtime..."
  if [[ "${skip_existing}" == "1" ]]; then
    exec env SFS_SKIP_SELF_UPGRADE=1 "${sfs_bin}" upgrade --skip-existing --no-self-upgrade
  fi
  exec env SFS_SKIP_SELF_UPGRADE=1 "${sfs_bin}" upgrade --no-self-upgrade
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

case "${1:-}" in
  /sfs|sfs|\$sfs)
    shift
    if [[ $# -eq 0 ]]; then
      usage
      exit 0
    fi
    ;;
esac

case "${1:-}" in
  init|install)
    shift
    exec bash "${DIST_DIR}/install.sh" --layout thin "$@"
    ;;
  agent)
    shift
    agent_command "$@"
    exit $?
    ;;
  context)
    shift
    context_command "$@"
    exit $?
    ;;
  upgrade)
    shift
    upgrade_command "$@"
    exit $?
    ;;
  update)
    shift
    echo "sfs update is a compatibility alias; prefer: sfs upgrade" >&2
    upgrade_command "$@"
    exit $?
    ;;
  version|-v|--version)
    shift || true
    version_command "$@"
    exit $?
    ;;
  uninstall)
    shift
    exec bash "${DIST_DIR}/uninstall.sh" "$@"
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
esac

case "${1:-}" in
  status|start|guide|auth|profile|division|adopt|brainstorm|plan|implement|review|decision|report|tidy|retro|commit|loop)
    if ! ensure_project_initialized "${1:-command}"; then
      exit 1
    fi
    maybe_show_stale_version_notice "${1:-command}"
    if [[ "${1:-}" == "guide" && ! -f "$(project_local_dir)/VERSION" ]]; then
      exit 0
    fi
    ;;
esac

export SFS_RUNTIME_DIR="${RUNTIME_DIR}"
export SFS_DIST_DIR="${DIST_DIR}"
export SFS_LOCAL_DIR="${SFS_LOCAL_DIR:-.sfs-local}"

exec bash "${RUNTIME_DIR}/scripts/sfs-dispatch.sh" "$@"
