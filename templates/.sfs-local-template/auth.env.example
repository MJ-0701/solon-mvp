# Optional local executor auth for Solon SFS.
# Copy this file to .sfs-local/auth.env and fill only what you use.
# .sfs-local/auth.env is gitignored by Solon.

# Provider API-key based auth (recommended for CI/headless SFS bridge):
# OPENAI_API_KEY=replace-me
# ANTHROPIC_API_KEY=replace-me
# GEMINI_API_KEY=replace-me
# GOOGLE_API_KEY=replace-me
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# If you already completed a CLI login flow and want SFS to trust that cached
# login for headless calls, opt in explicitly:
# SFS_CODEX_AUTH_READY=1
# SFS_CLAUDE_AUTH_READY=1
# SFS_GEMINI_AUTH_READY=1

# Check or bootstrap local CLI/browser auth from a real terminal:
# /sfs auth status
# /sfs auth login codex
# /sfs auth login --executor codex|claude|gemini
# /sfs auth probe --executor codex|claude|gemini --timeout 20
#
# Review also checks auth before running. If auth is missing and a real terminal
# is available, `/sfs review --run` can bootstrap auth automatically. Use
# `--no-auth-interactive` for CI/fail-closed behavior.

# Optional full command overrides. These receive the generated prompt on stdin.
# SFS_REVIEW_GEMINI_CMD='gemini --skip-trust --output-format text -p "Read stdin and perform the requested CPO review."'
# SFS_REVIEW_CODEX_CMD='codex exec --full-auto'
# SFS_REVIEW_CLAUDE_CMD='claude -p --dangerously-skip-permissions'
#
# Windows Store Codex note:
# Do not point SFS_REVIEW_CODEX_CMD at the package-private
# C:\Program Files\WindowsApps\OpenAI.Codex_...\app\resources\codex.exe path;
# Windows may deny direct execution. Use the App Execution Alias (`codex`) or
# an accessible shim such as /c/Users/<you>/AppData/Local/Microsoft/WindowsApps/codex.exe.
#
# Desktop/web apps without a CLI are manual fallback only:
# sfs review --gate <id> --executor codex --prompt-only
# Then paste the generated prompt into the app yourself, or use another
# installed CLI executor such as Claude CLI.
